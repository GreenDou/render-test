    "preview": "vite preview"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:GreenDou/render-test.git"
  },
  "homepage": "https://greendou.github.io/render-test/",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@webgpu/types": "^0.1.69",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^7.1.9",
    "wabt": "^1.0.37"
  }
}
