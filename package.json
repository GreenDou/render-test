{
  "name": "render-test",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Mobile-friendly rendering benchmark demo comparing WebGL/WebGPU and TypeScript/WebAssembly simulation paths.",
  "scripts": {
